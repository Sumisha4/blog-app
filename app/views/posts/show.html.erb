<% content_for :title, "Showing post" %>

<div class="max-w-2xl mx-auto">
  <% if @post.cover_image.attached? %>
    <%= image_tag @post.cover_image, class: "w-full rounded-lg mb-6" %>
  <% end %>

  <h1 class="font-bold text-4xl"><%= @post.title %></h1>
  <p class="mt-4 text-gray-600">By <%= @post.user.name %> · <%= time_ago_in_words(@post.created_at) %> ago</p>
  <div class="mt-6 text-lg leading-relaxed"><%= @post.body %></div>

  <div class="mt-6 flex gap-2">
    <%= link_to "Back", posts_path, class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium" %>
    <% if user_signed_in? && @post.user_id == current_user.id %>
      <%= link_to "Edit", edit_post_path(@post), class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium" %>
      <%= button_to "Delete", @post, method: :delete, class: "rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
      <%= button_to @post.published? ? "Unpublish" : "Publish", publish_post_path(@post), method: :patch, class: "rounded-md px-3.5 py-2.5 #{@post.published? ? 'bg-yellow-500 hover:bg-yellow-400' : 'bg-green-600 hover:bg-green-500'} text-white font-medium cursor-pointer" %>
    <% end %>
  </div>

  <hr class="my-8" />

  <h2 class="font-bold text-2xl mb-4">Comments (<%= @post.comments.count %>)</h2>

  <% @post.comments.each do |comment| %>
    <div class="bg-white border border-gray-200 rounded-lg p-4 mb-3">
      <p class="text-sm text-gray-500 mb-1"><%= comment.user.name %> · <%= time_ago_in_words(comment.created_at) %> ago</p>
      <p><%= comment.body %></p>
      <% if user_signed_in? && comment.user == current_user %>
        <%= button_to "Delete", post_comment_path(@post, comment), method: :delete, class: "text-red-500 text-sm mt-2 cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
      <% end %>
    </div>
  <% end %>

  <% if user_signed_in? %>
    <h3 class="font-bold text-xl mt-6 mb-3">Add a comment</h3>
    <%= form_with url: post_comments_path(@post), model: [@post, Comment.new] do |f| %>
      <div class="mb-3">
        <%= f.text_area :body, rows: 3, placeholder: "Write your comment...", class: "w-full border border-gray-300 rounded-lg p-3" %>
      </div>
      <%= f.submit "Post Comment", class: "bg-purple-600 text-white px-4 py-2 rounded-lg cursor-pointer" %>
    <% end %>
  <% else %>
    <p class="mt-6 text-gray-500"><%= link_to "Log in", new_user_session_path, class: "text-purple-600" %> to leave a comment.</p>
  <% end %>
</div>