<% content_for :title, "Posts" %>

<div class="max-w-2xl mx-auto">

  <div class="flex justify-between items-center mb-8">
    <h1 class="font-bold text-4xl">Posts</h1>
  </div>

  <% if @posts.any? %>
    <% @posts.each do |post| %>
      <% cache [post, current_user&.id] do %>
        <div class="bg-white border border-gray-200 rounded-lg p-6 mb-4 hover:shadow-sm transition">
          <div class="flex justify-between items-start">
            <div>
            <h2 class="font-bold text-xl mb-1">
              <%= link_to post.title, post, class: "hover:text-purple-600 underline decoration-purple-300" %>
            </h2>
              <p class="text-gray-500 text-sm">By <%= post.user.name %> · <%= time_ago_in_words(post.created_at) %> ago</p>
              <p class="text-gray-700 mt-3"><%= post.body.truncate(150) %></p>
            </div>
            <% if user_signed_in? && post.user_id == current_user.id %>
              <div class="flex gap-2 ml-4">
                <%= link_to "Edit", edit_post_path(post), class: "text-sm rounded-md px-3 py-2 bg-gray-100 hover:bg-gray-50 font-medium" %>
                <%= button_to "Delete", post, method: :delete, class: "text-sm rounded-md px-3 py-2 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <p class="text-center my-10 text-gray-500">No posts found. Be the first to write one!</p>
  <% end %>
</div>