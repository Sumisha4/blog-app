<div class="max-w-sm w-full mx-auto mt-10 bg-white border border-gray-200 rounded-xl p-8">
  <h1 class="font-bold text-3xl mb-6 text-center">Log in</h1>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="mb-4">
      <%= f.label :email, class: "block font-medium mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block font-medium mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="mb-4 flex items-center gap-2">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me %>
      </div>
    <% end %>

    <div class="mt-6">
      <%= f.submit "Log in", class: "w-full bg-purple-600 hover:bg-purple-500 text-white font-medium py-2 px-4 rounded-lg cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-4 text-sm text-gray-600 text-center">
    <%= render "devise/shared/links" %>
  </div>
</div>