<div class="max-w-sm w-full mx-auto mt-10 bg-white border border-gray-200 rounded-xl p-8">
  <h1 class="font-bold text-3xl mb-2 text-center">Forgot your password?</h1>
  <p class="text-gray-500 text-sm text-center mb-6">Enter your email and we'll send you reset instructions.</p>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-4">
      <%= f.label :email, class: "block font-medium mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
    </div>

    <div class="mt-6">
      <%= f.submit "Send reset instructions", class: "w-full bg-purple-600 hover:bg-purple-500 text-white font-medium py-2 px-4 rounded-lg cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-4 text-sm text-gray-600 text-center">
    <%= render "devise/shared/links" %>
  </div>
</div>